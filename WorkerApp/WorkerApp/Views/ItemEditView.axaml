<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WorkerApp.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="WorkerApp.Views.ItemEditView"
             x:DataType="vm:ItemsEditViewModel"
             Background="#e0f4ff">

     <UserControl.Styles>
        <!-- Primary gomb stílus -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#0078d4" />   <!-- erős kék -->
            <Setter Property="Foreground" Value="White" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Height" Value="40" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,0" />
        </Style>

        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="#005a9e" />
        </Style>
    </UserControl.Styles>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Fejléc -->
            <RowDefinition Height="*" />      <!-- Scrollos mezők -->
            <RowDefinition Height="Auto" />   <!-- Fix gombsor -->
        </Grid.RowDefinitions>

        <!-- Fejléc -->
        <Border Grid.Row="0"
                Background="#ffffff"
                CornerRadius="8"
                Padding="10"
                BoxShadow="0 2 6 #20000000">
            <TextBlock Text="Cikk szerkesztése"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#004071"
                       HorizontalAlignment="Center" />
        </Border>

        <!-- Mezők (scrollolható rész) -->
        <ScrollViewer Grid.Row="1" Margin="0,12,0,12">
            <Border Background="#f5fbff"
                    CornerRadius="8"
                    Padding="12"
                    BoxShadow="0 2 6 #15000000">
                <StackPanel Spacing="10">

                    <TextBlock Text="Név"
                               FontWeight="SemiBold"
                               Foreground="#00324e" />
                    <TextBox Text="{Binding ItemName}"
                             Background="White"
                             Foreground="Black"
                             BorderBrush="#0078d4"
                             Watermark="Cikk neve" />

                    <TextBlock Text="Kategória"
                               FontWeight="SemiBold"
                               Foreground="#00324e"
                               Margin="0,6,0,0" />
                    <TextBox Text="{Binding CategoryName}"
                             Background="White"
                             Foreground="Black"
                             BorderBrush="#0078d4"
                             Watermark="Kategória neve" />

                    <TextBlock Text="Mennyiség"
                               FontWeight="SemiBold"
                               Foreground="#00324e"
                               Margin="0,6,0,0" />
                    <TextBox Text="{Binding Quantity}"
                             Background="White"
                             Foreground="Black"
                             BorderBrush="#0078d4"
                             Watermark="Darabszám" />

                    <TextBlock Text="Ár (Ft)"
                               FontWeight="SemiBold"
                               Foreground="#00324e"
                               Margin="0,6,0,0" />
                    <TextBox Text="{Binding Price}"
                             Background="White"
                             Foreground="Black"
                             BorderBrush="#0078d4"
                             Watermark="Egységár" />

                    <TextBlock Text="Leírás"
                               FontWeight="SemiBold"
                               Foreground="#00324e"
                               Margin="0,6,0,0" />
                    <TextBox Text="{Binding Description}"
                             Background="White"
                             Foreground="Black"
                             BorderBrush="#0078d4"
                             AcceptsReturn="True"
                             Height="80"
                             TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Fixen alul lévő gombok -->
        <StackPanel Grid.Row="2"
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            Spacing="8">
    <Button Content="Mégse"
            Background="#ffffff"
            Foreground="#00324e"
            BorderBrush="#0078d4"
            BorderThickness="1"
            Padding="12,0"
            Command="{Binding CancelCommand}" />   

    <Button Content="Mentés"
            Classes="primary"
            Command="{Binding SaveCommand}" />
</StackPanel>
    </Grid>
</UserControl>